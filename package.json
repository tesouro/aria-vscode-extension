{
  "name": "aria-api-editor",
  "displayName": "ARIA API Editor",
  "description": "Extensao VS Code para editar projetos ARIA via API",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscode.microsoft-authentication"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ariaExplorer",
          "title": "ARIA",
          "icon": "resources/aria.svg"
        }
      ]
    },
    "views": {
      "ariaExplorer": [
        {
          "id": "ariaProjectsView",
          "name": "Projetos ARIA",
          "icon": "resources/aria.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ariaProjectsView",
        "contents": "### Acesso necessario\nEntre com sua conta institucional para carregar os projetos do ARIA.\n\n[Entrar com Tesouro.gov.br](command:aria.connect)",
        "when": "!aria.isLoggedIn"
      }
    ],
    "commands": [
      {
        "command": "aria.connect",
        "title": "ARIA: Conectar na API",
        "icon": "$(account)"
      },
      {
        "command": "aria.refreshTree",
        "title": "ARIA: Atualizar Arvore",
        "icon": "$(refresh)"
      },
      {
        "command": "aria.editProjectJson",
        "title": "Editar JSON"
      },
      {
        "command": "aria.editProjectForm",
        "title": "Editar em Formulario"
      },
      {
        "command": "aria.editEndpointCode",
        "title": "Editar Código",
        "icon": "$(edit)"
      },
      {
        "command": "aria.editEndpointJson",
        "title": "Editar JSON",
        "icon": "$(file-code)"
      },
      {
        "command": "aria.editEndpointForm",
        "title": "Editar em Formulario",
        "icon": "$(list-tree)"
      },
      {
        "command": "aria.saveActiveEditor",
        "title": "ARIA: Salvar Alteracoes via API",
        "icon": "$(save)"
      },
      {
        "command": "aria.validateActiveEditor",
        "title": "ARIA: Validar Codigo via API",
        "icon": "$(pass)"
      },
      {
        "command": "aria.openLastPayload",
        "title": "ARIA: Abrir Ultimo Payload do importa_json",
        "icon": "$(output)"
      },
      {
        "command": "aria.createEndpoint",
        "title": "Novo Endpoint",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aria.connect",
          "when": "view == ariaProjectsView",
          "group": "navigation@1"
        },
        {
          "command": "aria.refreshTree",
          "when": "view == ariaProjectsView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aria.editEndpointCode",
          "when": "view == ariaProjectsView && viewItem == ariaEndpoint",
          "group": "inline"
        },
        {
          "command": "aria.editEndpointCode",
          "when": "view == ariaProjectsView && viewItem == ariaEndpoint",
          "group": "aria@1"
        },
        {
          "command": "aria.editEndpointJson",
          "when": "view == ariaProjectsView && viewItem == ariaEndpoint",
          "group": "aria@2"
        },
        {
          "command": "aria.editEndpointForm",
          "when": "view == ariaProjectsView && viewItem == ariaEndpoint",
          "group": "aria@3"
        },
        {
          "command": "aria.createEndpoint",
          "when": "view == ariaProjectsView && viewItem == ariaProject",
          "group": "inline"
        },
        {
          "command": "aria.createEndpoint",
          "when": "view == ariaProjectsView && viewItem == ariaProject",
          "group": "aria@1"
        },
        {
          "command": "aria.editProjectJson",
          "when": "view == ariaProjectsView && viewItem == ariaProject",
          "group": "aria@2"
        },
        {
          "command": "aria.editProjectForm",
          "when": "view == ariaProjectsView && viewItem == ariaProject",
          "group": "aria@3"
        }
      ],
      "editor/title": [
        {
          "command": "aria.saveActiveEditor",
          "when": "resourceFilename =~ /\\.aria\\.(json|sql|py)$/",
          "group": "navigation"
        },
        {
          "command": "aria.validateActiveEditor",
          "when": "resourceFilename =~ /\\.aria\\.(sql|py)$/",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "ARIA API Editor",
      "properties": {
        "ariaApi.baseUrl": {
          "type": "string",
          "default": "https://ms-aria.appsdev.ocp.tesouro.gov.br/",
          "description": "URL base da API ARIA VSCode"
        },
        "ariaApi.fetchProjectPath": {
          "type": "string",
          "default": "",
          "description": "Opcional: filtrar leitura por TX_PATH do projeto"
        },
        "ariaApi.ignoreSslErrors": {
          "type": "boolean",
          "default": true,
          "description": "Ignora erros SSL/TLS ao conectar com a API"
        },
        "ariaApi.requireEntraLogin": {
          "type": "boolean",
          "default": true,
          "description": "Exige login Microsoft Entra ID antes de conectar na API"
        },
        "ariaApi.allowedEmailDomains": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Opcional: lista de dominios de e-mail permitidos para login Entra ID"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "aria.assistant",
        "name": "aria",
        "description": "Assistente ARIA - responde perguntas sobre endpoints e projetos carregados na extensao",
        "isSticky": false
      }
    ],
    "languageModelTools": [
      {
        "name": "aria_create_endpoint",
        "displayName": "ARIA: Criar Novo Endpoint",
        "modelDescription": "Cria um novo endpoint no ARIA montando um REST_CUSTOM no formato padrao esperado pela API (estrutura base fixa) e aplicando um novo TX_PATH. Requer name e path. O projeto pode ser informado por projectId ou projectName (nome do projeto), e se nao vier, o comando tenta detectar automaticamente pela arvore de projetos/contexto. Campos opcionais: code (TX_CODIGO), method (1=GET 2=POST 3=PUT 4=DELETE), description (DS_REST_CUSTOM_CURTA). Ao criar, o comando tenta inferir defaults de metodo/conexao e valida campos obrigatorios do formulario de endpoint.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "aria_create_endpoint",
        "inputSchema": {
          "type": "object",
          "required": ["name", "path"],
          "properties": {
            "projectId": {
              "type": "number",
              "description": "ID do projeto ARIA onde o endpoint sera criado. Opcional quando projectName for informado."
            },
            "projectName": {
              "type": "string",
              "description": "Nome do projeto ARIA alvo (NO_PROJETO), por exemplo: API Series Temporais."
            },
            "name": {
              "type": "string",
              "description": "Nome do endpoint (NO_REST_CUSTOM)."
            },
            "path": {
              "type": "string",
              "description": "Caminho do endpoint (TX_PATH), ex: /usuarios."
            },
            "code": {
              "type": "string",
              "description": "Codigo SQL ou Python do endpoint (TX_CODIGO)."
            },
            "method": {
              "type": "number",
              "description": "Metodo HTTP: 1=GET, 2=POST, 3=PUT, 4=DELETE. Padrao: 1."
            },
            "description": {
              "type": "string",
              "description": "Descricao curta do endpoint (DS_REST_CUSTOM_CURTA)."
            }
          }
        }
      },
      {
        "name": "aria_list_endpoints",
        "displayName": "ARIA: Listar Endpoints do Projeto",
        "modelDescription": "Lista todos os endpoints do projeto ARIA atualmente sendo editado (ou de um projeto especifico pelo ID). Retorna nome, caminho (TX_PATH), metodo HTTP e descricao de cada endpoint. Use esta ferramenta para entender o contexto do projeto quando o usuario estiver editando um endpoint.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "aria_list_endpoints",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": {
              "type": "number",
              "description": "ID do projeto ARIA. Se omitido, usa o projeto do arquivo sendo editado no momento."
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {}
}
